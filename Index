<script>
  /* ═══════════════════════════════════════════════════
     ⚙️ الإعداد — الصق هنا رابط Google Apps Script
     (الخطوات كاملة في ملف google-apps-script-التعليمات.gs)
     الرابط يبدأ بـ:
     https://script.google.com/macros/s/XXXXX/exec
  ═══════════════════════════════════════════════════ */
  const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzuqUtME0FKnmb69csILunrmOtrdFmoDgMse99lDTBY6ym5FRZBhbUsNv70OxOPJfxuYg/exec";

  const WORDS = ['مَدْرَسَة','حَقِيبَة','نَافِذَة','مَكْتَبَة','الْحَدِيقَة','الْعَصَافِير','الْمُعَلِّمَة','التَّعَاوُن','الْمَسْؤُولِيَّة','الْمُحَافَظَة'];
  const state = new Array(10).fill(false);
  let sent = false;

  function toggle(i){
    state[i] = !state[i];
    document.querySelector('.card[data-i="'+i+'"]').classList.toggle('done', state[i]);
    update();
  }

  function update(){
    const n = state.filter(Boolean).length;
    const sc = document.getElementById('score');
    sc.innerHTML = n + '<b>/10</b>';
    sc.classList.remove('pop'); void sc.offsetWidth; sc.classList.add('pop');
    for(let k=0;k<3;k++) document.getElementById('lvl'+k).classList.remove('active');
    const msg = document.getElementById('msg');
    if(n===0){ msg.textContent='اضغط على المربعات أثناء القراءة 👆'; return; }
    const lvl = n<=3?0 : n<=7?1 : 2;
    document.getElementById('lvl'+lvl).classList.add('active');
    msg.textContent = n===10 ? 'رائع! 10 من 10 👏👏' : (lvl===2 ? 'ممتاز! واصل 👏' : lvl===1 ? 'جيد! يحتاج بعض التدريب' : 'استمروا بالتدريب اليومي');
  }

  function resetAll(){
    state.fill(false); sent = false;
    document.querySelectorAll('.card').forEach(c=>c.classList.remove('done'));
    const btn = document.getElementById('sendBtn');
    btn.disabled = false; btn.classList.remove('ok');
    document.getElementById('sendLabel').textContent = 'أرسل النتيجة للمعلمة';
    update();
  }

  function showToast(t, err){
    const el = document.getElementById('toast');
    el.textContent = t;
    el.classList.toggle('err', !!err);
    el.classList.add('show');
    setTimeout(()=>el.classList.remove('show'), 3000);
  }

  function closeOverlay(){ document.getElementById('overlay').classList.remove('show'); }

  async function sendResult(){
    if(sent){ showToast('تم إرسال النتيجة مسبقًا ✅'); return; }
    const name = document.getElementById('pname').value.trim();
    if(!name){ showToast('الرجاء كتابة اسم الطفل أولاً ✏️', true); document.getElementById('pname').focus(); return; }
    if(SCRIPT_URL.indexOf('http') !== 0){ showToast('لم يتم ربط الصفحة بجدول Google بعد — راجع ملف التعليمات ⚙️', true); return; }

    const grade = document.getElementById('pgrade').value;
    const n = state.filter(Boolean).length;
    const lvl = n<=3 ? 'يحتاج تأسيس' : n<=7 ? 'جيد ويحتاج تدريب' : 'ممتاز';
    const payload = {
      name: name,
      grade: grade,
      score: n,
      level: lvl,
      results: state.map(v => v ? 1 : 0),
      wrong: WORDS.filter((w,i)=>!state[i])
    };

    const btn = document.getElementById('sendBtn');
    btn.disabled = true;
    document.getElementById('spinner').style.display = 'inline-block';
    document.getElementById('planeIcon').style.display = 'none';
    document.getElementById('sendLabel').textContent = 'جارٍ الإرسال...';

    try {
      await fetch(SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(payload)
      });
      sent = true;
      btn.classList.add('ok');
      document.getElementById('sendLabel').textContent = 'تم الإرسال ✅';
      document.getElementById('overlay').classList.add('show');
    } catch(e) {
      btn.disabled = false;
      document.getElementById('sendLabel').textContent = 'أرسل النتيجة للمعلمة';
      showToast('تعذر الإرسال — تحقق من اتصال الإنترنت وحاول مجددًا', true);
    } finally {
      document.getElementById('spinner').style.display = 'none';
      document.getElementById('planeIcon').style.display = sent ? 'none' : 'inline-block';
    }
  }

  function fit(){
    const w = Math.min(document.documentElement.clientWidth, 1080);
    const s = w/1080;
    const sc = document.getElementById('scaler');
    sc.style.transform = 'scale('+s+')';
    sc.style.width = '1080px';
    sc.parentElement.style.height = 1600*s + 'px';
  }
  window.addEventListener('resize', fit);
  fit();
</script>
</body>
</html>
