<style>
  @font-face { font-family:'Kufi';  src:url(data:font/woff2;base64,) format('woff2'); }
  @font-face { font-family:'SansAr';src:url(data:font/woff2;base64,) format('woff2'); }
  :root{ --blue:#123D8D; --green:#7AC943; --ink:#0E2F6E; }
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  body{ background:#EDF1F8; font-family:'Kufi',sans-serif; }
  .stage{ width:100%; display:flex; justify-content:center; }
  .scaler{ transform-origin:top center; }

  .frame{
    position:relative; width:1080px; height:1560px;
    background:#fff; overflow:hidden;
    padding:42px 48px 40px;
    display:flex; flex-direction:column;
  }
  .glow{position:absolute;border-radius:50%;filter:blur(90px);z-index:0;pointer-events:none;}
  .g1{width:520px;height:520px;background:rgba(18,61,141,.05);top:-180px;left:-160px;}
  .g2{width:560px;height:560px;background:rgba(122,201,67,.07);bottom:-200px;right:-180px;}
  .frame>*{position:relative;z-index:2;}

  .topbar{display:flex;align-items:center;justify-content:space-between;height:78px;}
  .topbar img{height:78px;}
  .toptag{
    font-size:21px;font-weight:600;color:var(--blue);
    background:rgba(18,61,141,.06); border:1.5px solid rgba(18,61,141,.14);
    padding:10px 22px;border-radius:100px; display:flex;align-items:center;gap:10px;
  }
  .toptag .dot{width:10px;height:10px;border-radius:50%;background:var(--green);}

  .header{
    margin-top:22px;
    background:linear-gradient(135deg,#123D8D 0%,#0E2F6E 100%);
    border-radius:28px; padding:26px 40px 22px; text-align:center;
    box-shadow:0 16px 34px rgba(18,61,141,.22); overflow:hidden;
  }
  .header::after{content:'';position:absolute;right:-60px;bottom:-110px;width:230px;height:230px;border-radius:50%;background:rgba(122,201,67,.16);}
  .header h1{color:#fff;font-size:52px;font-weight:800;line-height:1.35;}
  .header p{margin-top:6px;color:var(--green);font-size:24px;font-weight:600;line-height:1.7;}
  .header p svg{vertical-align:-5px;margin:0 4px;}

  .who{ margin-top:18px; display:flex; gap:16px; }
  .field{
    flex:1.6; min-width:0; overflow:hidden;
    display:flex; align-items:center; gap:14px;
    background:#fff; border:2px solid rgba(18,61,141,.16); border-radius:18px;
    padding:0 22px; height:74px;
    box-shadow:0 6px 16px rgba(14,47,110,.06);
  }
  .field label{font-size:22px;font-weight:700;color:var(--blue);white-space:nowrap;}
  .field input{
    flex:1; min-width:0; width:100%;
    border:none; outline:none; font-family:'Kufi',sans-serif;
    font-size:24px; font-weight:600; color:var(--ink); background:transparent;
  }
  .field input::placeholder{color:rgba(14,47,110,.3);}
  .field.grade{flex:1;}
  .field select{
    flex:1; min-width:0; width:100%;
    border:none; outline:none; font-family:'Kufi',sans-serif;
    font-size:22px; font-weight:600; color:var(--ink); background:transparent; cursor:pointer;
  }

  .grid{
    margin-top:18px; flex:1;
    display:grid; grid-template-columns:1fr 1fr; grid-template-rows:repeat(5,1fr);
    gap:15px;
  }
  .card{
    background:#fff; border:1.5px solid rgba(18,61,141,.10);
    border-radius:22px; box-shadow:0 8px 22px rgba(14,47,110,.07);
    display:flex; align-items:center; padding:0 24px; gap:18px;
    cursor:pointer; user-select:none;
    transition:transform .15s ease, box-shadow .2s ease, border-color .2s ease, background .2s ease;
  }
  .card:hover{transform:translateY(-2px);box-shadow:0 12px 26px rgba(14,47,110,.12);}
  .card:active{transform:scale(.98);}
  .card.done{border-color:rgba(122,201,67,.65);background:rgba(122,201,67,.06);}
  .num{
    width:46px;height:46px;flex:0 0 46px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    color:#fff;font-size:23px;font-weight:700;
  }
  .num.b{background:var(--blue);box-shadow:0 5px 12px rgba(18,61,141,.30);}
  .num.g{background:var(--green);box-shadow:0 5px 12px rgba(122,201,67,.35);}
  .word{
    flex:1;text-align:center;font-family:'SansAr',sans-serif;
    font-size:48px;font-weight:700;color:var(--ink);line-height:2.1;padding-bottom:4px;
  }
  .box{
    width:56px;height:56px;flex:0 0 56px;
    border:3.5px solid var(--blue); border-radius:14px;
    background:rgba(122,201,67,.06);
    display:flex;align-items:center;justify-content:center;
    transition:background .2s ease, border-color .2s ease;
  }
  .box .tick{width:34px;height:34px;opacity:0;transform:scale(.3);transition:all .22s cubic-bezier(.5,1.6,.4,1);}
  .card.done .box{background:var(--green);border-color:var(--green);box-shadow:0 6px 14px rgba(122,201,67,.4);}
  .card.done .tick{opacity:1;transform:scale(1);}

  .bottom{margin-top:20px;display:flex;gap:16px;height:200px;}
  .rate{
    flex:1.15; background:rgba(122,201,67,.09);
    border:1.5px solid rgba(122,201,67,.45); border-radius:24px;
    padding:14px 26px 12px; display:flex;flex-direction:column;justify-content:space-between;
  }
  .rate h3{font-size:24px;font-weight:800;color:var(--blue);display:flex;align-items:center;gap:12px;}
  .rate h3 .pill{height:13px;width:44px;border-radius:100px;background:var(--green);}
  .rrow{
    display:flex;align-items:center;gap:14px;
    font-size:20.5px;font-weight:600;color:var(--ink);
    padding:5px 12px;border-radius:14px;transition:background .25s ease, box-shadow .25s ease;
  }
  .rrow .sbox{
    width:29px;height:29px;flex:0 0 29px;border-radius:8px;
    border:2.5px solid var(--blue);background:#fff;
    display:flex;align-items:center;justify-content:center;transition:all .25s ease;
  }
  .rrow .sbox svg{width:17px;height:17px;opacity:0;transform:scale(.3);transition:all .25s ease;}
  .rrow.active{background:#fff;box-shadow:0 6px 16px rgba(122,201,67,.25);}
  .rrow.active .sbox{background:var(--green);border-color:var(--green);}
  .rrow.active .sbox svg{opacity:1;transform:scale(1);}
  .rrow .lvl{color:var(--blue);font-weight:800;}
  .rrow .arrow{color:var(--green);font-weight:800;}

  .cta{
    flex:1; background:#fff;
    border:1.5px solid rgba(18,61,141,.10); border-radius:24px;
    box-shadow:0 14px 30px rgba(14,47,110,.10);
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:12px 24px;gap:6px;
  }
  .cta h3{font-size:26px;font-weight:800;color:var(--blue);line-height:1.5;}
  .score{
    font-size:42px;font-weight:800;color:var(--blue);
    background:rgba(18,61,141,.06);border-radius:100px;padding:2px 34px;
    direction:ltr; transition:transform .2s ease;
  }
  .score.pop{transform:scale(1.15);}
  .score b{color:var(--green);}
  .cta p{font-size:19px;font-weight:700;color:#5FA82E;line-height:1.5;min-height:29px;}

  .actions{margin-top:20px;display:flex;gap:16px;}
  .btn{
    font-family:'Kufi',sans-serif;font-weight:700;color:#fff;border:none;border-radius:100px;
    cursor:pointer;transition:transform .15s ease, box-shadow .2s ease, opacity .2s ease;
    display:flex;align-items:center;justify-content:center;gap:12px;
  }
  .btn:hover{transform:translateY(-2px);}
  .btn:active{transform:scale(.97);}
  .btn:disabled{opacity:.6;cursor:default;transform:none;}
  .send{
    flex:2; height:84px; font-size:27px;
    background:linear-gradient(135deg,#2ecc71,#7AC943);
    box-shadow:0 12px 26px rgba(122,201,67,.4);
  }
  .send.ok{background:linear-gradient(135deg,#123D8D,#0E2F6E);box-shadow:0 12px 26px rgba(18,61,141,.35);}
  .again{
    flex:1; height:84px; font-size:23px;
    background:var(--blue);
    box-shadow:0 10px 24px rgba(18,61,141,.3);
  }
  .hint{ margin-top:14px;text-align:center;font-size:18px;font-weight:600;color:rgba(14,47,110,.55); }

  .spinner{
    width:28px;height:28px;border-radius:50%;
    border:4px solid rgba(255,255,255,.35);border-top-color:#fff;
    animation:spin .8s linear infinite; display:none;
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  .toast{
    position:fixed; bottom:30px; left:50%; transform:translateX(-50%) translateY(140px);
    background:var(--blue); color:#fff; font-family:'Kufi',sans-serif;
    font-size:17px; font-weight:600; padding:14px 28px; border-radius:100px;
    box-shadow:0 12px 30px rgba(14,47,110,.35); transition:transform .3s ease; z-index:99;
    max-width:92vw; text-align:center;
  }
  .toast.show{transform:translateX(-50%) translateY(0);}
  .toast.err{background:#C0392B;}

  .overlay{
    position:fixed; inset:0; background:rgba(14,47,110,.55);
    display:none; align-items:center; justify-content:center; z-index:100; padding:20px;
  }
  .overlay.show{display:flex;}
  .modal{
    background:#fff; border-radius:28px; padding:44px 40px 36px; text-align:center;
    max-width:440px; width:100%;
    box-shadow:0 30px 70px rgba(0,0,0,.3);
    animation:pop .35s cubic-bezier(.5,1.6,.4,1);
  }
  @keyframes pop{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
  .modal .bigtick{
    width:96px;height:96px;border-radius:50%;background:var(--green);
    margin:0 auto 20px; display:flex;align-items:center;justify-content:center;
    box-shadow:0 14px 30px rgba(122,201,67,.45);
  }
  .modal h2{font-size:27px;font-weight:800;color:var(--blue);line-height:1.5;}
  .modal p{margin-top:10px;font-size:19px;font-weight:600;color:rgba(14,47,110,.65);line-height:1.7;}
  .modal button{
    margin-top:24px; font-family:'Kufi',sans-serif;
    font-size:20px;font-weight:700;color:#fff;background:var(--blue);
    border:none;border-radius:100px;padding:13px 42px;cursor:pointer;
  }
</style>
</head>
